"},{"kind":"typeIdentifier","text":"Value"},{"kind":"text","text":">."},{"kind":"typeIdentifier","text":"Element","preciseIdentifier":"s:18OrderedCollections0A10DictionaryV7Elementa","identifier":"doc:\/\/OrderedCollections\/documentation\/OrderedCollections\/OrderedDictionary\/Element"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"kind":"text","text":") "},{"kind":"keyword","text":"rethrows"}]}],"kind":"declarations"},{"parameters":[{"name":"areInIncreasingOrder","content":[{"inlineContent":[{"text":"A predicate that returns ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" if its","type":"text"},{"text":" ","type":"text"},{"text":"first argument should be ordered before its second argument;","type":"text"},{"text":" ","type":"text"},{"text":"otherwise, ","type":"text"},{"type":"codeVoice","code":"false"},{"text":". If ","type":"text"},{"type":"codeVoice","code":"areInIncreasingOrder"},{"text":" throws an error during","type":"text"},{"text":" ","type":"text"},{"text":"the sort, the elements may be in a different order, but none will be","type":"text"},{"text":" ","type":"text"},{"text":"lost.","type":"text"}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"When you want to sort a collection of elements that don’t conform to","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"code":"Comparable","type":"codeVoice"},{"text":" protocol, pass a closure to this method that returns","type":"text"},{"text":" ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" when the first element should be ordered before the second.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Alternatively, use this method to sort a collection of elements that do","type":"text"},{"text":" ","type":"text"},{"text":"conform to ","type":"text"},{"code":"Comparable","type":"codeVoice"},{"text":" when you want the sort to be descending instead","type":"text"},{"text":" ","type":"text"},{"text":"of ascending. Pass the greater-than operator (","type":"text"},{"code":">","type":"codeVoice"},{"text":") operator as the","type":"text"},{"text":" ","type":"text"},{"text":"predicate.","type":"text"}]},{"type":"paragraph","inlineContent":[{"code":"areInIncreasingOrder","type":"codeVoice"},{"text":" must be a ","type":"text"},{"inlineContent":[{"type":"text","text":"strict weak ordering"}],"type":"emphasis"},{"text":" over the","type":"text"},{"text":" ","type":"text"},{"text":"elements. That is, for any elements ","type":"text"},{"code":"a","type":"codeVoice"},{"text":", ","type":"text"},{"code":"b","type":"codeVoice"},{"text":", and ","type":"text"},{"code":"c","type":"codeVoice"},{"text":", the following","type":"text"},{"text":" ","type":"text"},{"text":"conditions must hold:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"areInIncreasingOrder(a, a)"},{"type":"text","text":" is always "},{"type":"codeVoice","code":"false"},{"type":"text","text":". (Irreflexivity)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"If "},{"code":"areInIncreasingOrder(a, b)","type":"codeVoice"},{"type":"text","text":" and "},{"code":"areInIncreasingOrder(b, c)","type":"codeVoice"},{"type":"text","text":" are"},{"type":"text","text":" "},{"type":"text","text":"both "},{"code":"true","type":"codeVoice"},{"type":"text","text":", then "},{"code":"areInIncreasingOrder(a, c)","type":"codeVoice"},{"type":"text","text":" is also "},{"code":"true","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"(Transitive comparability)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Two elements are ","type":"text"},{"inlineContent":[{"type":"text","text":"incomparable"}],"type":"emphasis"},{"text":" if neither is ordered before the other","type":"text"},{"text":" ","type":"text"},{"text":"according to the predicate. If ","type":"text"},{"code":"a","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"b","type":"codeVoice"},{"text":" are incomparable, and ","type":"text"},{"code":"b","type":"codeVoice"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"code":"c","type":"codeVoice"},{"text":" are incomparable, then ","type":"text"},{"code":"a","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"c","type":"codeVoice"},{"text":" are also incomparable.","type":"text"},{"text":" ","type":"text"},{"text":"(Transitive incomparability)","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"The sorting algorithm is not guaranteed to be stable. A stable sort","type":"text"},{"text":" ","type":"text"},{"text":"preserves the relative order of elements for which","type":"text"},{"text":" ","type":"text"},{"code":"areInIncreasingOrder","type":"codeVoice"},{"text":" does not establish an order.","type":"text"}]},{"name":"Complexity","type":"aside","content":[{"inlineContent":[{"text":"O(","type":"text"},{"inlineContent":[{"text":"n","type":"text"}],"type":"emphasis"},{"text":" log ","type":"text"},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"text":"), where ","type":"text"},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"text":" is the length of the collection.","type":"text"}],"type":"paragraph"}],"style":"note"}],"kind":"content"}],"schemaVersion":{"major":0,"minor":2,"patch":0},"sections":[],"metadata":{"symbolKind":"method","roleHeading":"Instance Method","role":"symbol","externalID":"s:18OrderedCollections0A10DictionaryV4sort2byySbx3key_q_5valuet_xAF_q_AGttKXE_tKF","title":"sort(by:)","extendedModule":"OrderedCollections","conformance":{"constraints":[{"code":"Key","type":"codeVoice"},{"type":"text","text":" conforms to "},{"code":"Hashable","