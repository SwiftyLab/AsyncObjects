pe":"text"}],"type":"paragraph"}],"name":"combine"}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You use this initializer to create a dictionary when you have a sequence"},{"type":"text","text":" "},{"type":"text","text":"of key-value tuples that might have duplicate keys. As the dictionary is"},{"type":"text","text":" "},{"type":"text","text":"built, the initializer calls the "},{"code":"combine","type":"codeVoice"},{"type":"text","text":" closure with the current and"},{"type":"text","text":" "},{"type":"text","text":"new values for any duplicate keys. Pass a closure as "},{"code":"combine","type":"codeVoice"},{"type":"text","text":" that"},{"type":"text","text":" "},{"type":"text","text":"returns the value to use in the resulting dictionary: The closure can"},{"type":"text","text":" "},{"type":"text","text":"choose between the two values, combine them to produce a new value, or"},{"type":"text","text":" "},{"type":"text","text":"even throw an error."}]},{"code":["let pairsWithDuplicateKeys = [(\"a\", 1), (\"b\", 2), (\"a\", 3), (\"b\", 4)]","","let firstValues = OrderedDictionary(","  pairsWithDuplicateKeys,","  uniquingKeysWith: { (first, _) in first })","\/\/ [\"a\": 1, \"b\": 2]","","let lastValues = OrderedDictionary(","  pairsWithDuplicateKeys,","  uniquingKeysWith: { (_, last) in last })","\/\/ [\"a\": 3, \"b\": 4]"],"type":"codeListing","syntax":null},{"name":"Complexity","content":[{"inlineContent":[{"text":"Expected O(","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"text":") on average, where ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"n","type":"text"}]},{"text":" is the count of","type":"text"},{"text":" ","type":"text"},{"text":"key-value pairs, if ","type":"text"},{"type":"codeVoice","code":"Key"},{"text":" implements high-quality hashing.","type":"text"}],"type":"paragraph"}],"type"