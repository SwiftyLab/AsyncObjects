dentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"persistent","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":" = false)","kind":"text"}],"platforms":["Linux"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"minimumCapacity","content":[{"inlineContent":[{"type":"text","text":"The minimum number of elements that the newly"},{"type":"text","text":" "},{"type":"text","text":"created dictionary should be able to store without reallocating its"},{"type":"text","text":" "},{"type":"text","text":"storage."}],"type":"paragraph"}]},{"name":"persistent","content":[{"inlineContent":[{"text":"If set to true, prevent removals from shrinking","type":"text"},{"text":" ","type":"text"},{"text":"storage below the specified capacity. By default, removals are allowed","type":"text"},{"text":" ","type":"text"},{"text":"to shrink storage below any previously reserved capacity.","type":"text"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Use this initializer to avoid intermediate reallocations of a dictionary’s"},{"type":"text","text":" "},{"type":"text","text":"storage buffer when you know in advance how many elements you’ll insert"},{"type":"text","text":" "},{"type":"text","text":"into it after creation."}],"type":"paragraph"},{"inlineContent":[{"text":"If you have a good idea of the expected working size of the dictionary,","type":"text"},{"text":" ","type":"text"},{"text":"calling this initializer with ","type":"text"},{"code":"persistent","type":"codeVoice"},{"text":" set to true can sometimes","type":"text"},{"text":" ","type":"text"},{"text":"improve performance by eliminating churn due to repeated rehashings when","type":"text"},{"text":" ","type":"text"},{"text":"the dictionary temporarily shrinks below its regular size. You can cancel","type":"text"},{"text":" ","type":"text"},{"text":"any capacity you’ve previously reserved by persistently reserving a","type":"text"},{"text":" ","type":"text"},{"text":"capacity of zero. (This also shrinks the hash table to the ideal size for","type":"text"},{"text":" ","type":"text"},{"text":"its current number elements.)","type":"text"}],"type":"paragraph"},{"name":"Complexity","type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"O("},{"type":"codeVoice","code":"minimumCapacity"},{"type":"text","text":")"}],"type":"paragraph"}]}]}],"references":{"doc://OrderedCollections/documentation/OrderedCollections/OrderedDictionary/init(minimumCapacity:persistent:)":{"abstract":[{"type":"text","text":"Creates an empty dictionary with preallocated space for at least the"},{"type":"text","text":" "},{"type":"text","text":"specified number of elements."}],"fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"minimumCapacity","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"persistent","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":")","kind":"text"}],"title":"init(minimumCapacity:persistent:)","kind":"symbol","type":"topic","role":"symbol","conformance":{"constraints":[{"type":"codeVoice","code":"Key"},{"text":" conforms to ","type":"text"},{"type":"codeVoice","code":"Hashable"},{"text":".","type":"text"}],"availabilityPrefix":[{"text":"Available when","type":"text"}],"conformancePrefix":[{"text":"Conforms when","type":"text"}]},"identifier":"doc:\/\/OrderedCollections\/documentation\/OrderedCollections\/OrderedDictionary\/init(minimumCapacity:persistent:)","url":"\/documentation\/orderedcollections\/ordereddictionary\/init(minimumcapacity:persistent:)"},"doc://OrderedCollections/documentation/OrderedCollections/Ord