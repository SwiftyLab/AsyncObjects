{"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"elements"},{"kind":"text","text":": ["},{"kind":"typeIdentifier","text":"Element"},{"kind":"text","text":"] { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" "},{"kind":"keyword","text":"set"},{"kind":"text","text":" }"}],"platforms":["Linux"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"It is possible to mutate the set by updating the value of this property."},{"type":"text","text":" "},{"type":"text","text":"This guarantees that direct mutations happen in place when possible (i.e.,"},{"type":"text","text":" "},{"type":"text","text":"without spurious copy-on-write copies)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"However, the set needs to ensure the uniqueness of its members, so every"},{"type":"text","text":" "},{"type":"text","text":"update to "},{"code":"elements","type":"codeVoice"},{"type":"text","text":" includes a postprocessing step to detect and remove"},{"type":"text","text":" "},{"type":"text","text":"duplicates over the entire array. This can be slower than doing the"},{"type":"text","text":" "},{"type":"text","text":"equivalent updates with direct "},{"code":"OrderedSet","type":"codeVoice"},{"type":"text","text":" operations, so updating"},{"type":"text","text":" "},{"code":"elements","type":"codeVoice"},{"type":"text","text":" is best used in cases where direct implementations aren’t"},{"type":"text","text":" "},{"type":"text","text":"available – for example, when you need to call a "},{"code":"MutableCollection","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"algorithm that isn’t directly implemented by "},{"code":"OrderedSet","type":"codeVoice"},{"type":"text","text":" itself."}],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"O(1) for the getter. Mutating this property has an expected","type":"text"},{"text":" ","type":"text"},{"text":"complexity of O(","type":"text"},{"code":"count","type":"codeVoice"},{"text":"), if ","type":"text"},{"code":"Element","type":"codeVoice"},{"text":" implements high-quality hashing.","type":"text"}],"type":"paragraph"}],"style":"note","type":"aside","name":"Complexity"}],"kind":"content"}],"abstract":[{"type":"text","text":"A view of the members of this set, as a regular array value."}],"schemaVersion":{"major":0,"patch":0,"minor":2},"identifier":{"url":"doc:\/\/OrderedCollections\/documentation\/OrderedCollections\/OrderedSet\/elements","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OrderedCollections\/documentation\/OrderedCollections","doc:\/\/OrderedCollections\/documentation\/OrderedCollections\/OrderedSet"]]},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/orderedcollections\/orderedset\/elements"]}],"metadata":{"modules":[{"name":"OrderedCollections"}],"roleHeading":"Instance Property","symbolKind":"property","role":"symbol","extendedModule":"OrderedCollections","title":"elements","externalID":"s:18OrderedCollections0A3SetV8elementsSayxGvp","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"elements","kind":"identifier"},{"text":": [","kind":"text"},{"text":"Element","kind":"typeIdentifier"},{"text":"]","kind":"text"}],"conformance":{"constraints":[{"type":"codeVoice","code":"Element"},{"type":"text","text":" conforms to "},{"type":"codeVoice","code":"Hashable"},{"type":"text","text":"."}],"availabilityPrefix":[{"type":"text","text":"Available when"}],"conformancePrefix":[{"type":"text","text":"Conforms when"}]}},"references":{"doc://OrderedCollections/documentation/OrderedCollections":{"kind":"symbol","type":"topic","identifier":"doc:\/\/OrderedCollections\/documentation\/OrderedCollections","role":"collection","abstract":[],"url":"\/documentation\/orderedcollections","title":"OrderedCollections"},"doc://OrderedCollections/documentation/OrderedCollections/OrderedSet":{"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"OrderedSet"}],"type":"topic","url":"\/documentation\/orderedcollections\/orderedset","title":"OrderedSet","abstract":[{"type":"text","text":"An ordered collection of unique elements."}],"identifier":"doc:\/\/OrderedCollections\/documentation\/OrderedCollections\/OrderedSet","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrderedSet"}]},"doc://OrderedCollections/documentation/OrderedCollections/OrderedSet/elements":{"kind":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"elements"},{"kind":"text","text":": ["},{"kind":"typeIdentifier","text":"Element"},{"kind":"text","text":"]"}],"abstract":[{"type":"text","text":"A view of the members of this set, as a regular array value."}],"type":"topic","role":"symbol","identifier":"doc:\/\/OrderedCollections\/documentation\/OrderedCollections\/OrderedSet\/elements","title":"elements","url":"\/documentation\/orderedcollections\/orderedset\/elements","conformance":{"constraints":[{"code":"Element","type":"codeVoice"},{"text":" conforms to ","type":"text"},{"code":"Hashable","type":"codeVoice"},{"text":".","type":"text"}],"availabilityPrefix":[{"text":"Available when","type":"text"}],"conformancePrefix":[{"text":"Conforms when","type":"text"}]}}}}